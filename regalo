<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Feliz Cumpleaños Camila ❤️</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;1,400;1,700&family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&display=swap" rel="stylesheet"/>
  <style>
    :root {
      --cream: #fff9f9;
      --rose: #c9536a;
      --rose-light: #e8a0aa;
      --rose-dark: #7a1f30;
      --ink: #2a1218;
      --ink-soft: #6a3040;
    }
    * { margin:0; padding:0; box-sizing:border-box; }
    body {
      background: radial-gradient(ellipse at 50% 40%, #200510 0%, #090204 100%);
      min-height:100vh;
      display:flex; align-items:center; justify-content:center;
      font-family:'Cormorant Garamond', serif;
      overflow:hidden;
    }
 
    /* BG rising hearts */
    #bg { position:fixed; inset:0; pointer-events:none; z-index:1; }
 
    /* ENVELOPE SCENE */
    #scene {
      position:relative; z-index:10;
      display:flex; flex-direction:column; align-items:center; gap:20px;
    }
    .scene-title {
      font-family:'Playfair Display',serif; font-style:italic;
      color:#f5b8c4; font-size:1.35rem; letter-spacing:0.06em;
      text-align:center; padding:0 20px;
      animation:sglow 3s ease-in-out infinite;
    }
    @keyframes sglow {
      0%,100%{ text-shadow:0 0 12px rgba(200,80,106,0.4); }
      50%{ text-shadow:0 0 32px rgba(200,80,106,0.95),0 0 60px rgba(200,80,106,0.3); }
    }
 
    /* Envelope */
    .envelope {
      width:360px; height:230px; position:relative; cursor:pointer;
      filter:drop-shadow(0 14px 50px rgba(180,50,80,0.55));
      transition:transform .3s, filter .3s;
    }
    .envelope:hover { transform:scale(1.05) rotate(-1deg); filter:drop-shadow(0 20px 65px rgba(200,60,90,.75)); }
    .env-body {
      position:absolute; inset:0;
      background:linear-gradient(150deg,#fde8ec 0%,#f9d4db 60%,#f0c0ca 100%);
      border-radius:4px 4px 10px 10px;
      border:1.5px solid rgba(200,100,120,.45);
    }
    .env-body::after { content:'❤️'; position:absolute; bottom:18px; right:22px; font-size:2rem; opacity:.13; }
    .env-fb { position:absolute; bottom:0; left:0; width:0; height:0; border-left:180px solid transparent; border-right:180px solid transparent; border-bottom:125px solid #f0c8d0; z-index:1; }
    .env-sl { position:absolute; bottom:0; left:0; width:0; height:0; z-index:2; border-top:115px solid transparent; border-bottom:115px solid transparent; border-left:180px solid #eabac4; }
    .env-sr { position:absolute; bottom:0; right:0; width:0; height:0; z-index:2; border-top:115px solid transparent; border-bottom:115px solid transparent; border-right:180px solid #e0aab5; }
    .env-ft { position:absolute; top:0; left:0; width:0; height:0; border-left:180px solid transparent; border-right:180px solid transparent; border-top:125px solid #f5ccd4; z-index:5; transform-origin:top center; transition:transform .85s cubic-bezier(.4,0,.2,1); }
    .envelope.open .env-ft { transform:rotateX(180deg); }
    .seal { position:absolute; top:50%; left:50%; transform:translate(-50%,-50%); width:58px; height:58px; background:radial-gradient(circle at 38% 32%,#e05070,#7a1f30); border-radius:50%; z-index:6; display:flex; align-items:center; justify-content:center; font-size:1.6rem; box-shadow:0 3px 16px rgba(120,30,50,.6),inset 0 1px 3px rgba(255,200,210,.3); transition:opacity .35s,transform .35s; }
    .envelope.open .seal { opacity:0; transform:translate(-50%,-50%) scale(0); }
    .hint { color:#f5b8c4; font-size:.88rem; letter-spacing:.22em; text-transform:uppercase; animation:pulse 2.2s ease-in-out infinite; }
    @keyframes pulse { 0%,100%{opacity:.35} 50%{opacity:.9} }
 
    /* OVERLAY */
    #ov { position:fixed; inset:0; z-index:100; display:flex; align-items:center; justify-content:center; background:rgba(8,0,4,.9); backdrop-filter:blur(10px); opacity:0; pointer-events:none; transition:opacity .7s; }
    #ov.show { opacity:1; pointer-events:all; }
 
    /* LETTER */
    .letter {
      background:var(--cream); width:min(660px,95vw); max-height:92vh;
      overflow-y:auto; border-radius:2px; padding:58px 54px 50px;
      position:relative;
      box-shadow:0 30px 100px rgba(0,0,0,.75),0 0 0 1.5px rgba(200,80,110,.3);
      transform:translateY(50px) scale(.95);
      transition:transform .75s cubic-bezier(.2,0,0,1) .1s;
    }
    #ov.show .letter { transform:translateY(0) scale(1); }
    .letter::before { content:''; position:absolute; inset:12px; border:1px solid rgba(200,80,110,.13); border-radius:1px; pointer-events:none; }
 
    /* Rising hearts inside letter */
    #lh { position:absolute; inset:0; pointer-events:none; overflow:hidden; z-index:0; }
 
    .corner { position:absolute; font-size:1.1rem; opacity:.28; }
    .corner.tl{top:16px;left:18px;} .corner.tr{top:16px;right:36px;}
    .corner.bl{bottom:16px;left:18px;} .corner.br{bottom:16px;right:18px;}
 
    .inner { position:relative; z-index:1; }
 
    .hearts-top { text-align:center; font-size:.95rem; letter-spacing:.5em; color:var(--rose-light); margin-bottom:14px; opacity:0; transition:opacity .5s .2s; }
    #ov.show .hearts-top { opacity:1; }
 
    .letter h1 { font-family:'Playfair Display',serif; font-size:2rem; color:var(--rose-dark); margin-bottom:6px; font-weight:400; font-style:italic; }
    .sub { font-size:.88rem; color:var(--rose); letter-spacing:.22em; text-transform:uppercase; margin-bottom:30px; font-weight:300; }
 
    .divider { display:flex; align-items:center; gap:10px; margin:0 auto 32px; justify-content:center; }
    .dl { width:55px; height:1px; background:linear-gradient(90deg,transparent,var(--rose-light)); }
    .dl.r { background:linear-gradient(90deg,var(--rose-light),transparent); }
 
    .letter p { font-size:1.11rem; line-height:1.98; color:var(--ink); margin-bottom:22px; font-weight:300; opacity:0; transform:translateY(14px); transition:opacity .65s,transform .65s; }
    #ov.show .letter p { opacity:1; transform:translateY(0); }
    #ov.show p:nth-of-type(1){transition-delay:.3s;}
    #ov.show p:nth-of-type(2){transition-delay:.55s;}
    #ov.show p:nth-of-type(3){transition-delay:.80s;}
    #ov.show p:nth-of-type(4){transition-delay:1.05s;}
    #ov.show p:nth-of-type(5){transition-delay:1.30s;}
    #ov.show p:nth-of-type(6){transition-delay:1.55s;}
    #ov.show p:nth-of-type(7){transition-delay:1.80s;}
    .letter p em { font-style:italic; color:var(--rose-dark); }
    .letter p strong { font-weight:400; color:var(--rose); }
 
    .promise-box {
      border:1px solid rgba(200,80,110,.28);
      background:rgba(200,80,110,.05);
      border-radius:4px; padding:16px 24px; margin:4px 0 26px;
      text-align:center;
      font-family:'Playfair Display',serif; font-style:italic;
      font-size:1.13rem; color:var(--rose-dark); line-height:1.75;
      opacity:0; transform:translateY(14px);
      transition:opacity .65s 1.6s,transform .65s 1.6s;
    }
    #ov.show .promise-box { opacity:1; transform:translateY(0); }
 
    .sig { margin-top:44px; text-align:right; opacity:0; transition:opacity .7s 2.3s; }
    #ov.show .sig { opacity:1; }
    .sig .label { font-size:.8rem; letter-spacing:.28em; text-transform:uppercase; color:var(--ink-soft); margin-bottom:4px; }
    .sig .name { font-family:'Playfair Display',serif; font-size:2.5rem; font-style:italic; color:var(--rose-dark); line-height:1.1; }
    .sig .sig-hearts { font-size:1.1rem; letter-spacing:.35em; margin-top:6px; color:var(--rose-light); }
 
    .close-btn { position:absolute; top:16px; right:18px; background:none; border:none; color:var(--ink-soft); font-size:1.3rem; cursor:pointer; opacity:.4; transition:opacity .2s,transform .25s; z-index:10; }
    .close-btn:hover { opacity:1; transform:rotate(90deg); }
 
    .hburst { position:fixed; pointer-events:none; z-index:99; animation:hfly 1.4s ease-out forwards; }
    @keyframes hfly { 0%{transform:translate(0,0) scale(.3);opacity:1;} 100%{transform:translate(var(--dx),var(--dy)) scale(1.6);opacity:0;} }
 
    #conf { position:fixed; inset:0; pointer-events:none; z-index:200; }
 
    .letter::-webkit-scrollbar{width:4px;}
    .letter::-webkit-scrollbar-thumb{background:var(--rose-light);border-radius:2px;}
 
    @media(max-width:520px){
      .letter{padding:42px 22px 36px;}
      .letter h1{font-size:1.65rem;}
      .letter p{font-size:1rem;}
      .sig .name{font-size:2rem;}
      .envelope{width:300px;height:195px;}
      .env-fb{border-left-width:150px;border-right-width:150px;border-bottom-width:105px;}
      .env-sl{border-top-width:97px;border-bottom-width:97px;border-left-width:150px;}
      .env-sr{border-top-width:97px;border-bottom-width:97px;border-right-width:150px;}
      .env-ft{border-left-width:150px;border-right-width:150px;border-top-width:105px;}
    }
  </style>
</head>
<body>
 
<canvas id="bg"></canvas>
<canvas id="conf"></canvas>
 
<div id="scene">
  <div class="scene-title">Para Camila &nbsp;❤️&nbsp; en su día especial</div>
  <div class="envelope" id="env" onclick="openEnv()">
    <div class="env-body"></div>
    <div class="env-fb"></div>
    <div class="env-sl"></div>
    <div class="env-sr"></div>
    <div class="seal">❤️</div>
    <div class="env-ft"></div>
  </div>
  <p class="hint">✦ toca para abrir ✦</p>
</div>
 
<div id="ov">
  <div class="letter">
    <button class="close-btn" onclick="closeIt()">✕</button>
    <div id="lh"></div>
    <span class="corner tl">❤️</span>
    <span class="corner tr">❤️</span>
    <span class="corner bl">❤️</span>
    <span class="corner br">❤️</span>
 
    <div class="inner">
      <div class="hearts-top">❤️ &nbsp; ❤️ &nbsp; ❤️ &nbsp; ❤️ &nbsp; ❤️</div>
 
      <h1>Mi amor, Camila,</h1>
      <div class="sub">❤️ &nbsp; feliz cumpleaños, vida mía &nbsp; ❤️</div>
 
      <div class="divider">
        <div class="dl"></div>
        <span style="color:var(--rose-light);font-size:.95rem;">❤️</span>
        <div class="dl r"></div>
      </div>
 
      <p><strong>Feliz cumpleaños, mi amor.</strong> Hoy es tu día, y aunque quisiera estar ahí contigo,
      abrazarte, llenarte de besos y hacerte sentir lo amada que eres con mis propios brazos,
      la distancia no me lo permite. Y eso duele. Pero aún así, <em>aquí estoy, pensando en ti,
      amándote desde donde estoy con todo lo que tengo.</em> ❤️</p>
 
      <p>Ojalá pudiera darte el regalo que de verdad mereces: estar juntos. Despertar ese día
      a tu lado, prepararte algo especial, verte sonreír de cerca. No hay regalo material que
      valga más que eso. <em>Poder estar contigo y llenarte de amor, del amor de tu hombre.</em>
      Ese es el regalo que mi corazón te quiere dar hoy. 💕</p>
 
      <p>Quiero que sepas, en este día tan especial, que <strong>no me vas a perder jamás.</strong>
      Sé que a veces el miedo aparece, que las dudas tocan tu puerta. Pero escúchame bien:
      ningún miedo tiene razón de existir, porque yo no me voy a ningún lado. Estoy aquí.
      Siempre voy a estar aquí. ❤️</p>
 
      <p class="promise-box">
        "No importa la distancia, no importan los obstáculos.<br>
        Soy tu hombre hoy, mañana y todos los días que sigan.<br>
        Nunca dejaré de serlo, Camila. Nunca."
      </p>
 
      <p>Llevamos <strong>2 años y 2 meses</strong> construyendo algo hermoso, algo que ni la distancia
      entre nuestros países ha podido romper. Eso no es casualidad, eso es amor real.
      Y yo voy a cuidarlo con todo lo que soy, porque desde el primer momento que te conocí
      supe que <em>eres la mujer de mi vida.</em> ❤️</p>
 
      <p>Así que en este cumpleaños, recibe todo mi amor desde lejos. Imagina que estoy ahí,
      que te abrazo fuerte, que te susurro al oído cuánto te amo, que te lleno de los besos
      que te debo. <strong>Ese día va a llegar.</strong> Y cuando llegue, voy a compensar
      cada momento que la distancia nos quitó. ❤️❤️</p>
 
      <p>Hoy y siempre, <em>eres mi todo.</em> Feliz cumpleaños, mi vida. Que este año nuevo
      que comienza para ti esté lleno de alegría, y que sepa que tiene a su hombre
      pensando en ella <strong>en cada momento de cada día.</strong> ❤️</p>
 
      <div class="sig">
        <div class="label">Tuyo para siempre, tu hombre,</div>
        <div class="name">Leonardo</div>
        <div class="sig-hearts">❤️ &nbsp; ❤️ &nbsp; ❤️</div>
      </div>
    </div>
  </div>
</div>
 
<script>
  /* BG rising hearts */
  const bgC = document.getElementById('bg');
  const bgX = bgC.getContext('2d');
  bgC.width = window.innerWidth; bgC.height = window.innerHeight;
  const BH = Array.from({length:30}, () => ({
    x:Math.random()*bgC.width, y:Math.random()*bgC.height,
    s:5+Math.random()*15, a:0.03+Math.random()*0.1,
    sp:0.15+Math.random()*0.55, dr:(Math.random()-.5)*.4
  }));
  function heartPath(ctx,x,y,s){
    ctx.beginPath();
    ctx.moveTo(x,y+s*.3);
    ctx.bezierCurveTo(x,y,x-s,y,x-s,y+s*.3);
    ctx.bezierCurveTo(x-s,y+s*.65,x,y+s*1.05,x,y+s*1.15);
    ctx.bezierCurveTo(x,y+s*1.05,x+s,y+s*.65,x+s,y+s*.3);
    ctx.bezierCurveTo(x+s,y,x,y,x,y+s*.3);
    ctx.closePath();
  }
  function bgLoop(){
    bgX.clearRect(0,0,bgC.width,bgC.height);
    BH.forEach(h=>{
      h.y-=h.sp; h.x+=h.dr;
      if(h.y<-30){h.y=bgC.height+30;h.x=Math.random()*bgC.width;}
      bgX.save(); bgX.globalAlpha=h.a; bgX.fillStyle='#c9536a';
      heartPath(bgX,h.x,h.y,h.s); bgX.fill(); bgX.restore();
    });
    requestAnimationFrame(bgLoop);
  }
  bgLoop();
  window.addEventListener('resize',()=>{bgC.width=window.innerWidth;bgC.height=window.innerHeight;});
 
  /* Rising hearts inside letter */
  const letterHeartStyle = document.createElement('style');
  letterHeartStyle.textContent = `
    @keyframes riseUp {
      0%  { opacity:.85; transform:translateY(0) scale(.6); }
      70% { opacity:.6; }
      100%{ opacity:0;  transform:translateY(-380px) translateX(var(--sx)) scale(1); }
    }
    .lheart {
      position:absolute; pointer-events:none;
      animation: riseUp var(--dur) ease-in forwards;
      font-size:var(--fs);
      left:var(--lx); bottom:-20px;
    }
  `;
  document.head.appendChild(letterHeartStyle);
 
  let lhInterval = null;
  function startLetterHearts(){
    const container = document.getElementById('lh');
    container.innerHTML = '';
    if(lhInterval) clearInterval(lhInterval);
    const syms = ['❤️','🩷','💗','💕','❤️','❤️','💖'];
    lhInterval = setInterval(()=>{
      const h = document.createElement('span');
      h.className = 'lheart';
      h.textContent = syms[Math.floor(Math.random()*syms.length)];
      h.style.setProperty('--lx', Math.random()*95+'%');
      h.style.setProperty('--dur', (3+Math.random()*4)+'s');
      h.style.setProperty('--fs', (.65+Math.random()*.95)+'rem');
      h.style.setProperty('--sx', ((Math.random()-.5)*60)+'px');
      container.appendChild(h);
      setTimeout(()=>h.remove(), 7500);
    }, 300);
  }
 
  /* Open */
  function openEnv(){
    const e = document.getElementById('env');
    if(e.classList.contains('open')) return;
    e.classList.add('open');
    burst(e);
    setTimeout(()=>{
      document.getElementById('ov').classList.add('show');
      launchConfetti();
      startLetterHearts();
    }, 680);
  }
  function closeIt(){
    document.getElementById('ov').classList.remove('show');
    if(lhInterval){ clearInterval(lhInterval); lhInterval=null; }
    setTimeout(()=>document.getElementById('env').classList.remove('open'),400);
  }
 
  /* Burst */
  function burst(origin){
    const r=origin.getBoundingClientRect();
    const cx=r.left+r.width/2, cy=r.top+r.height/2;
    const syms=['❤️','🩷','💗','💕','💖','❤️'];
    for(let i=0;i<26;i++){
      const h=document.createElement('span');
      h.className='hburst'; h.textContent=syms[Math.floor(Math.random()*syms.length)];
      const ang=Math.random()*Math.PI*2, dist=60+Math.random()*190;
      h.style.left=cx+'px'; h.style.top=cy+'px';
      h.style.setProperty('--dx',Math.cos(ang)*dist+'px');
      h.style.setProperty('--dy',Math.sin(ang)*dist+'px');
      h.style.animationDelay=Math.random()*.45+'s';
      h.style.fontSize=(1.1+Math.random()*1.3)+'rem';
      document.body.appendChild(h);
      h.addEventListener('animationend',()=>h.remove());
    }
  }
 
  /* Confetti */
  function launchConfetti(){
    const cv=document.getElementById('conf');
    const cx=cv.getContext('2d');
    cv.width=window.innerWidth; cv.height=window.innerHeight;
    const cols=['#c9536a','#e8a0aa','#7a1f30','#fde8ec','#f5b8c4','#ffccd5','#fff0f2','#ff8fa3'];
    const pp=Array.from({length:200},()=>({
      x:Math.random()*cv.width, y:-20-Math.random()*250,
      w:4+Math.random()*9, h:3+Math.random()*6,
      col:cols[Math.floor(Math.random()*cols.length)],
      vx:-2+Math.random()*4, vy:1.5+Math.random()*3.5,
      ang:Math.random()*Math.PI*2, sp:-0.06+Math.random()*.12,
      circ:Math.random()>.55
    }));
    function draw(){
      cx.clearRect(0,0,cv.width,cv.height);
      let alive=false;
      pp.forEach(p=>{
        p.x+=p.vx;p.y+=p.vy;p.ang+=p.sp;p.vy+=.05;
        if(p.y<cv.height+30)alive=true;
        cx.save();cx.translate(p.x,p.y);cx.rotate(p.ang);
        cx.globalAlpha=Math.min(1,(cv.height-p.y)/100);
        cx.fillStyle=p.col;
        if(p.circ){cx.beginPath();cx.arc(0,0,p.w/2,0,Math.PI*2);cx.fill();}
        else cx.fillRect(-p.w/2,-p.h/2,p.w,p.h);
        cx.restore();
      });
      if(alive)requestAnimationFrame(draw);
      else cx.clearRect(0,0,cv.width,cv.height);
    }
    requestAnimationFrame(draw);
  }
 
  document.getElementById('ov').addEventListener('click',function(e){
    if(e.target===this)closeIt();
  });
</script>
</body>
</html>
